// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(CLIENT)
  phone     String?
  avatar    String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  applications Application[]
  inquiries    Inquiry[]
  favorites    Favorite[]
  documents    Document[]
  notifications Notification[]
  testimonials Testimonial[]
  blogPosts    BlogPost[]
  chatMessages  ChatMessage[]
}

enum UserRole {
  CLIENT
  ADMIN
}

model Country {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  description String?
  flagUrl     String?
  costOfLiving Float?  // Average monthly cost
  currency    String?  @default("USD")
  language    String?
  climate     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  universities University[]
  visaInfo     VisaInfo?
  scholarships Scholarship[]
}

model University {
  id          String   @id @default(cuid())
  name        String
  countryId   String
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  description String?
  website     String?
  logoUrl     String?
  coverImage  String?
  commission  Float    @default(0) // Commission percentage
  ranking     Int?
  acceptanceRate Float? // Percentage
  totalStudents Int?
  internationalStudents Int?
  establishedYear Int?
  address     String?
  email       String?
  phone       String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  programs    Program[]
  applications Application[]
  scholarships Scholarship[]
}

model Program {
  id           String   @id @default(cuid())
  universityId String
  university   University @relation(fields: [universityId], references: [id], onDelete: Cascade)
  name         String
  degree       String   // Bachelor, Master, PhD, etc.
  field        String?  // Engineering, Business, Arts, etc.
  duration     Int      // Duration in months
  tuitionFee   Float?
  currency     String?  @default("USD")
  description  String?
  requirements String?  // JSON string or text
  intakeMonths String?  // JSON array: ["January", "September"]
  language     String?  @default("English")
  ieltsRequired Float?  // Minimum IELTS score
  toeflRequired Int?    // Minimum TOEFL score
  gpaRequired  Float?   // Minimum GPA
  applicationDeadline DateTime?
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  applications Application[]
  scholarships Scholarship[]
}

model VisaInfo {
  id          String   @id @default(cuid())
  countryId   String   @unique
  country     Country  @relation(fields: [countryId], references: [id], onDelete: Cascade)
  requirements String? // JSON string or text
  processingTime String?
  cost        Float?
  documents   String?  // JSON array of required documents
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  inquiries Inquiry[]
}

model Inquiry {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])
  name        String
  email       String
  phone       String?
  message     String?
  status      InquiryStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum InquiryStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model Application {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  universityId String
  university  University @relation(fields: [universityId], references: [id])
  programId   String
  program     Program  @relation(fields: [programId], references: [id])
  status      ApplicationStatus @default(DRAFT)
  documents   String?  // JSON array of document URLs from MinIO
  notes       String?
  submittedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  documentFiles Document[]
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  WITHDRAWN
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   // Rich text content
  coverImage  String?
  authorId    String?
  author      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  views       Int      @default(0)
  tags        String?  // JSON array
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime?
}

model Testimonial {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name      String
  email     String?
  content   String
  rating    Int      @default(5) // 1-5 stars
  country   String?
  university String?
  approved  Boolean  @default(false)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Scholarship {
  id          String   @id @default(cuid())
  title       String
  description String?
  amount      Float?
  currency    String   @default("USD")
  countryId   String?
  country     Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)
  universityId String?
  university  University? @relation(fields: [universityId], references: [id], onDelete: SetNull)
  programId   String?
  program     Program? @relation(fields: [programId], references: [id], onDelete: SetNull)
  deadline    DateTime?
  requirements String? // JSON or text
  link        String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      FavoriteType
  itemId    String   // ID of the favorited item (university, program, scholarship)
  createdAt DateTime @default(now())
  
  @@unique([userId, type, itemId])
}

enum FavoriteType {
  UNIVERSITY
  PROGRAM
  SCHOLARSHIP
}

model Document {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        String   // passport, transcript, recommendation, etc.
  url         String   // MinIO URL
  size        Int?     // File size in bytes
  mimeType    String?
  applicationId String?
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

enum NotificationType {
  APPLICATION_UPDATE
  INQUIRY_RESPONSE
  SCHOLARSHIP_DEADLINE
  SYSTEM
  GENERAL
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name      String
  email     String
  message   String
  response  String?
  status    ChatStatus @default(PENDING)
  adminId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ChatStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Analytics {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  type      String   // page_view, inquiry, application, etc.
  value     Int      @default(1)
  metadata  String?  // JSON data
  createdAt DateTime @default(now())
}

